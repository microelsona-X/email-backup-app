{
  "name": "mailguardian",
  "version": "1.0.0",
  "description": "MailGuardian - 邮件守护者：安全可靠的跨平台邮件备份工具",
  "productName": "MailGuardian",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "generate:icons": "node scripts-generate-icons.cjs",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.mailguardian.app",
    "productName": "MailGuardian",
    "files": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dist-electron",
        "to": "dist-electron",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build",
        "to": "build",
        "filter": [
          "**/*"
        ]
      },
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  },
  "keywords": [
    "email",
    "backup",
    "electron",
    "imap",
    "outlook",
    "gmail"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@azure/msal-node": "^5.0.5",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "antd": "^5.12.0",
    "date-fns": "^4.1.0",
    "electron-store": "^8.1.0",
    "global-tunnel-ng": "^2.7.1",
    "googleapis": "^168.0.0",
    "i18next": "^25.8.13",
    "imap": "^0.8.19",
    "imapflow": "^1.2.10",
    "mailparser": "^3.9.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.4",
    "socks": "^2.8.7",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/imap": "^0.8.43",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.9.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
